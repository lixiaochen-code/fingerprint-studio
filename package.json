{
  "name": "auto-registry",
  "version": "0.1.0",
  "private": true,
  "description": "Local profile manager for isolated ecommerce browser environments.",
  "main": "dist-electron/main.js",
  "scripts": {
    "browser:install": "browsers install chrome@stable --path .browsers",
    "browser:install:chromium": "browsers install chromium@latest --path .browsers",
    "browser:list": "browsers list --path .browsers",
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"tsc -p tsconfig.electron.json && wait-on tcp:5173 && electron .\"",
    "build": "tsc -p tsconfig.json && vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.1",
    "@puppeteer/browsers": "^2.13.0",
    "@vitejs/plugin-react": "^5.0.4",
    "antd": "^6.3.7",
    "concurrently": "^9.2.1",
    "electron": "39.8.9",
    "lucide-react": "^0.468.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^7.2.6",
    "wait-on": "^9.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3"
  }
}

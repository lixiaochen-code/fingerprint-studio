{
  "name": "auto-registry",
  "version": "0.1.8",
  "private": true,
  "description": "Local profile manager for isolated ecommerce browser environments.",
  "main": "dist-electron/main.js",
  "scripts": {
    "browser:install": "browsers install chrome@stable --path .browsers",
    "browser:install:chromium": "browsers install chromium@latest --path .browsers",
    "browser:list": "browsers list --path .browsers",
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"tsc -p tsconfig.electron.json && wait-on tcp:127.0.0.1:5173 && electron .\"",
    "build": "tsc -p tsconfig.json && cross-env NODE_OPTIONS=--max-old-space-size=8192 vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview --host 127.0.0.1",
    "validate:specs": "node scripts/validate-specs.mjs",
    "cloud:server": "node scripts/cloud-server.mjs",
    "archive": "node scripts/archive-change.mjs",
    "dist:check": "node scripts/verify-electron-cache.mjs",
    "dist": "pnpm run dist:check && pnpm run build && electron-builder",
    "dist:mac": "pnpm run dist:check && pnpm run build && electron-builder --mac",
    "dist:win": "pnpm run dist:check && pnpm run build && electron-builder --win",
    "dist:linux": "pnpm run dist:check && pnpm run build && electron-builder --linux",
    "dist:all": "pnpm run dist:check && pnpm run build && electron-builder -mwl"
  },
  "build": {
    "appId": "com.autoregistry.app",
    "productName": "Fingerprint Studio",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/7zip-bin/**",
      "**/node_modules/@esbuild/**",
      "**/node_modules/esbuild/bin/**",
      "**/node_modules/.pnpm/@esbuild+*/**",
      "**/node_modules/.pnpm/esbuild@*/**"
    ],
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme,test,tests,*.d.ts,*.map}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "7zip-bin": "^5.2.0",
    "@monaco-editor/react": "^4.7.0",
    "@puppeteer/browsers": "^2.13.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "axios": "^1.16.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "esbuild": "^0.28.0",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.55.1",
    "node-7z": "^3.0.0",
    "puppeteer-core": "^24.43.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.15.1",
    "rebrowser-puppeteer-core": "^24.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^22.10.2",
    "@types/node-7z": "^2.1.11",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "39.8.9",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.14",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "wait-on": "^9.0.3"
  }
}
